---
import Layout from "../layouts/Layout.astro";
---

<Layout title="홈">
  <div class="flex h-full flex-col">
    <!-- 히어로 -->
    <div class="flex flex-1 flex-col items-center justify-center px-8 py-24 text-center">
      <!-- 마크 -->
      <div class="mb-8 flex size-20 items-center justify-center rounded-[22px] bg-accent shadow-[0_8px_32px_rgba(79,70,229,0.4)]">
        <div class="flex flex-col justify-center gap-[4px] px-[14px]" style="width:52px;height:44px;">
          <div class="h-[3.5px] w-full rounded-full bg-white"></div>
          <div class="h-[3.5px] w-[58%] rounded-full bg-white"></div>
        </div>
      </div>

      <div class="mb-3 text-[11px] font-bold uppercase tracking-widest text-accent-text">
        Design System
      </div>
      <h1 class="mb-4 text-[48px] font-bold leading-tight tracking-[-0.03em] text-ink">
        blommunity
      </h1>
      <p class="mb-10 max-w-lg text-[17px] leading-relaxed text-ink-2">
        멀티테넌트 커뮤니티 플랫폼의 디자인 시스템.
        콘솔, 어드민, 커뮤니티 — 세 개의 서피스를 하나의 브랜드로.
      </p>

      <div class="flex items-center gap-3">
        <a
          href="/foundations/colors"
          class="inline-flex h-10 items-center gap-2 rounded-[6px] bg-accent px-5 text-[14px] font-semibold text-white transition-colors hover:bg-accent-hover"
        >
          파운데이션 보기
        </a>
        <a
          href="/components/button"
          class="inline-flex h-10 items-center gap-2 rounded-[6px] border border-line-strong bg-surface-1 px-5 text-[14px] font-semibold text-ink transition-colors hover:bg-surface-2"
        >
          컴포넌트 보기
        </a>
      </div>
    </div>

    <!-- 세 서피스 소개 -->
    <div class="border-t border-line px-8 py-12">
      <div class="mx-auto grid max-w-4xl grid-cols-3 gap-4">
        {[
          {
            label: "테넌트 콘솔",
            desc: "사업자 CMS — 스페이스, 게시판, 멤버, 설정 관리",
            token: "--bl-*",
            bg: "bg-surface-2",
          },
          {
            label: "운영자 어드민",
            desc: "플랫폼 내부 — 테넌트 승인, 운영자 역할, 감사 로그",
            token: "--bl-*",
            bg: "bg-surface-2",
          },
          {
            label: "유저 커뮤니티",
            desc: "회원 대상 — 피드, 게시글, 댓글, 초대, 프로필",
            token: "--cm-*",
            bg: "bg-[#f4f3ef]",
          },
        ].map((s) => (
          <div class="rounded-xl border border-line bg-surface-1 p-5">
            <div class={["mb-3 h-16 rounded-lg", s.bg].join(" ")} />
            <p class="text-[13px] font-bold text-ink">{s.label}</p>
            <p class="mt-1 text-[12px] leading-relaxed text-ink-3">{s.desc}</p>
            <code class="mt-2 inline-block text-[11px] text-accent-text">{s.token}</code>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
