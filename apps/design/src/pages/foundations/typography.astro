---
import DocLayout from "../../layouts/DocLayout.astro";
import Preview from "../../components/Preview.astro";
---

<DocLayout
  title="타이포그래피"
  description="Inter (라틴 UI) + Pretendard (한국어). 두 폰트는 메트릭스가 일치해 자연스럽게 혼용됩니다."
>

  <!-- 폰트 패밀리 -->
  <h2 class="mb-4 text-[17px] font-bold text-ink">폰트 패밀리</h2>
  <div class="mb-8 grid grid-cols-2 gap-4">
    {[
      { name: "Inter", sample: "Aa Bb Cc 123", desc: "라틴 UI, 영문 숫자" },
      { name: "Pretendard", sample: "가나다 Aa 123", desc: "한국어 본문 및 UI" },
    ].map((f) => (
      <div class="rounded-xl border border-line bg-surface-1 p-6">
        <p class="mb-1 text-[11px] font-semibold uppercase tracking-widest text-ink-3">{f.name}</p>
        <p class="text-[40px] font-bold leading-none tracking-tight text-ink" style={`font-family:'${f.name}',sans-serif`}>
          {f.sample}
        </p>
        <p class="mt-3 text-[12px] text-ink-3">{f.desc}</p>
      </div>
    ))}
  </div>

  <!-- 타입 스케일 -->
  <h2 class="mb-4 text-[17px] font-bold text-ink">타입 스케일</h2>
  <div class="mb-8 overflow-hidden rounded-xl border border-line bg-surface-1">
    {[
      { token: "--fs-display", size: "30px", label: "Display",  sample: "커뮤니티에 오신 걸 환영해요" },
      { token: "--fs-h1",      size: "21px", label: "H1",       sample: "스페이스 목록" },
      { token: "--fs-h2",      size: "17px", label: "H2",       sample: "북클럽 소개" },
      { token: "--fs-prose",   size: "17px", label: "Prose",    sample: "오늘의 독서 기록을 남겨보세요." },
      { token: "--fs-body",    size: "14px", label: "Body",     sample: "기본 UI 본문 텍스트입니다." },
      { token: "--fs-sm",      size: "13px", label: "Small",    sample: "보조 텍스트, 테이블 셀" },
      { token: "--fs-xs",      size: "12px", label: "XS",       sample: "메타, 캡션" },
      { token: "--fs-micro",   size: "11px", label: "Micro",    sample: "BADGE · EYEBROW" },
    ].map((s, i) => (
      <div class={["flex items-baseline gap-6 px-5 py-4", i > 0 ? "border-t border-line" : ""].join(" ")}>
        <div class="w-20 shrink-0">
          <p class="text-[11px] font-semibold text-accent-text">{s.label}</p>
          <code class="text-[10px] text-ink-3">{s.size}</code>
        </div>
        <p class="flex-1 text-ink" style={`font-size:${s.size}`}>{s.sample}</p>
        <code class="shrink-0 text-[10px] text-ink-3">{s.token}</code>
      </div>
    ))}
  </div>

  <!-- 웨이트 -->
  <h2 class="mb-4 text-[17px] font-bold text-ink">웨이트</h2>
  <Preview label="Font Weights">
    {[
      { w: 400, label: "Regular" },
      { w: 500, label: "Medium" },
      { w: 600, label: "SemiBold" },
      { w: 700, label: "Bold" },
      { w: 800, label: "Black (로고 전용)" },
    ].map((f) => (
      <div class="flex-1 min-w-36">
        <p class="text-[28px] leading-tight text-ink" style={`font-weight:${f.w}`}>블로뮤니티</p>
        <p class="mt-1 text-[12px] text-ink-3">{f.w} — {f.label}</p>
      </div>
    ))}
  </Preview>

  <!-- 트래킹 -->
  <h2 class="mb-4 mt-8 text-[17px] font-bold text-ink">레터 스페이싱</h2>
  <div class="rounded-xl border border-line bg-surface-1 p-6">
    {[
      { label: "헤딩", tracking: "-0.035em", sample: "스페이스 목록" },
      { label: "소제목", tracking: "-0.02em", sample: "북클럽 소개" },
      { label: "본문", tracking: "0", sample: "오늘의 독서 기록을 남겨보세요." },
      { label: "아이브로우", tracking: "0.06em", sample: "BADGE LABEL" },
    ].map((t, i) => (
      <div class={["flex items-center gap-6 py-3", i > 0 ? "border-t border-line" : ""].join(" ")}>
        <p class="w-20 text-[11px] font-semibold text-ink-3">{t.label}</p>
        <p class="flex-1 text-[17px] font-bold text-ink" style={`letter-spacing:${t.tracking}`}>{t.sample}</p>
        <code class="text-[11px] text-ink-3">{t.tracking}</code>
      </div>
    ))}
  </div>
</DocLayout>
