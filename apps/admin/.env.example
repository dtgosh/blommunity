# Base URL the admin app uses to reach the backend API.
# Default points at the Next.js rewrite proxy (see next.config.ts) so the browser
# avoids CORS issues with the NestJS backend (which has no CORS enabled).
NEXT_PUBLIC_API_BASE_URL=/api-proxy

# Origin of the NestJS backend (apps/backend). Used server-side by next.config rewrites.
# The backend listens on port 3000 by default and has NO /api or /v1 route prefix.
BACKEND_ORIGIN=http://localhost:3000
