{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/api/tsconfig.app.json",
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "introspectComments": true
        }
      }
    ]
  },
  "monorepo": true,
  "root": "apps/api",
  "projects": {
    "admin": {
      "type": "library",
      "root": "libs/admin",
      "entryFile": "index",
      "sourceRoot": "libs/admin/src",
      "compilerOptions": {
        "tsConfigPath": "libs/admin/tsconfig.lib.json"
      }
    },
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "board": {
      "type": "library",
      "root": "libs/board",
      "entryFile": "index",
      "sourceRoot": "libs/board/src",
      "compilerOptions": {
        "tsConfigPath": "libs/board/tsconfig.lib.json"
      }
    },
    "cache": {
      "type": "library",
      "root": "libs/cache",
      "entryFile": "index",
      "sourceRoot": "libs/cache/src",
      "compilerOptions": {
        "tsConfigPath": "libs/cache/tsconfig.lib.json"
      }
    },
    "comment": {
      "type": "library",
      "root": "libs/comment",
      "entryFile": "index",
      "sourceRoot": "libs/comment/src",
      "compilerOptions": {
        "tsConfigPath": "libs/comment/tsconfig.lib.json"
      }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/config/tsconfig.lib.json"
      }
    },
    "db": {
      "type": "library",
      "root": "libs/db",
      "entryFile": "index",
      "sourceRoot": "libs/db/src",
      "compilerOptions": {
        "tsConfigPath": "libs/db/tsconfig.lib.json"
      }
    },
    "post": {
      "type": "library",
      "root": "libs/post",
      "entryFile": "index",
      "sourceRoot": "libs/post/src",
      "compilerOptions": {
        "tsConfigPath": "libs/post/tsconfig.lib.json"
      }
    },
    "space": {
      "type": "library",
      "root": "libs/space",
      "entryFile": "index",
      "sourceRoot": "libs/space/src",
      "compilerOptions": {
        "tsConfigPath": "libs/space/tsconfig.lib.json"
      }
    },
    "tenant": {
      "type": "library",
      "root": "libs/tenant",
      "entryFile": "index",
      "sourceRoot": "libs/tenant/src",
      "compilerOptions": {
        "tsConfigPath": "libs/tenant/tsconfig.lib.json"
      }
    },
    "user": {
      "type": "library",
      "root": "libs/user",
      "entryFile": "index",
      "sourceRoot": "libs/user/src",
      "compilerOptions": {
        "tsConfigPath": "libs/user/tsconfig.lib.json"
      }
    },
    "util": {
      "type": "library",
      "root": "libs/util",
      "entryFile": "index",
      "sourceRoot": "libs/util/src",
      "compilerOptions": {
        "tsConfigPath": "libs/util/tsconfig.lib.json"
      }
    }
  }
}