{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["generate", "^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".astro/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": {},
    "check-types": {
      "dependsOn": ["generate", "transit"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "generate": {
      "inputs": ["../../apps/backend/apps/api/openapi.json"],
      "outputs": ["src/generated/**"]
    }
  }
}
